/* 场馆头部信息 */
.venue-header {
  background: linear-gradient(135deg, #0052D9 0%, #5E7CE0 100%);
  color: white;
  padding: 40rpx;
  position: relative;
  padding-top: 20rpx;
}

.venue-image {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(45deg, #0052D9, #5E7CE0);
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
}

.venue-info {
  margin-bottom: 40rpx;
}

.venue-name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.venue-address {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.venue-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
}

/* 场馆详细信息 */
.venue-details {
  padding: 32rpx;
  background-color: #fff;
}

.info-title {
  font-size: 32rpx !important;
  font-weight: 600 !important;
  color: #333 !important;
  padding-left: 0 !important;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 16rpx 0;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #666;
}

/* 约球留言板 */
.message-board {
  padding: 32rpx;
  background: #f5f5f5;
  padding-bottom: 240rpx; /* 为底部导航栏留出空间 */
}

.board-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.board-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.board-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* 留言组 */
.message-group {
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 留言项目 */
.message-item {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.message-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  background: #e5e7eb;
  color: #6b7280;
  font-weight: 600;
}

.user-details {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.message-time {
  font-size: 24rpx;
  color: #999;
}

.message-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.game-time {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.game-remark {
  font-size: 28rpx;
  color: #666;
}

.message-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
}

.signup-count {
  font-size: 24rpx;
  color: #999;
}

/* 底部导航栏间距 */
.t-tab-bar {
  position: fixed !important;
  bottom: 0 !important;
  left: 0 !important;
  right: 0 !important;
  z-index: 1000;
  margin-bottom: env(safe-area-inset-bottom);
}
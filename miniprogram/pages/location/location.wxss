.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.location-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.location-info {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.label {
  color: #888888;
  font-size: 28rpx;
}

.value {
  color: #333333;
  font-size: 32rpx;
  font-weight: 500;
}

.error-message {
  margin-top: 32rpx;
  padding: 24rpx;
  background-color: #fff2f0;
  border-radius: 8rpx;
  color: #fa5151;
  font-size: 28rpx;
  line-height: 1.5;
}

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.loading-text {
  color: #888888;
  font-size: 28rpx;
}

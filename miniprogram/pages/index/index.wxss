/* 容器样式 */
.location-container {
  padding: 12rpx 32rpx;
  background-color: #ffffff;
}

.location-info {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.label {
  color: #888888;
  font-size: 28rpx;
}

.value {
  color: #333333;
  font-size: 28rpx;
  font-weight: 500;
}

.error-message {
  padding: 16rpx;
  background-color: #fff2f0;
  border-radius: 8rpx;
  color: #fa5151;
  font-size: 28rpx;
  line-height: 1.5;
}

.loading-container {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
}

.loading-text {
  color: #888888;
  font-size: 28rpx;
}

/* 按钮容器 */
.button-container {
  padding: 12rpx 32rpx;
  background-color: #ffffff;
  z-index: 100;
  position: relative;
}

/* 地图容器 */
.map-container {
  width: 100%;
  height: calc(100vh - 220rpx);
  position: relative;
}
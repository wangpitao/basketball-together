<!-- 位置信息 -->
<view class="location-container">
  <view class="location-info" wx:if="{{locationSuccess}}">
    <view class="info-item">
      <view class="label">当前位置</view>
      <view class="value">{{latitude}}, {{longitude}}</view>
    </view>
  </view>
  
  <view class="error-message" wx:if="{{locationError}}">
    <text>{{errorMessage}}</text>
  </view>
  
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="40rpx" />
    <text class="loading-text">定位中...</text>
  </view>
</view>

<!-- 获取位置按钮 -->
<view class="button-container">
  <t-button theme="primary" size="large" icon="location" block bindtap="getLocation" disabled="{{loading}}">
    {{locationSuccess ? '重新获取位置' : '获取当前位置'}}
  </t-button>
</view>

<!-- 地图组件 -->
<view class="map-container">
  <map
    id="myMap"
    longitude="{{longitude}}"
    latitude="{{latitude}}"
    scale="{{scale}}"
    markers="{{markers}}"
    show-location
    bindregionchange="onRegionChange"
    bindcallouttap="onMarkerTap"
    bindmarkertap="onMarkerTap"
    style="width: 100%; height: 100%;"
  ></map>
</view>


.page {
  padding: 16px;
}
.section {
  background: #fff;
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 12px;
  border: 1px solid #e5e7eb;
}
.title {
  font-size: 16px;
  font-weight: 600;
  color: #111827;
}
.title.small {
  font-size: 14px;
}
.sub {
  margin-top: 6px;
  font-size: 12px;
  color: #6b7280;
}
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.comment {
  padding: 12px 0;
  border-bottom: 1px solid #f3f4f6;
}
.c-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}
.avatar {
  width: 28px;
  height: 28px;
  border-radius: 14px;
  background: #f3f4f6;
}
.name {
  font-size: 12px;
  color: #111827;
}
.time {
  font-size: 12px;
  color: #9ca3af;
}
.c-content {
  font-size: 14px;
  color: #111827;
}
.comment-input {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-top: 8px;
}
.ipt {
  flex: 1;
  height: 36px;
  padding: 0 10px;
  background: #f9fafb;
  border-radius: 8px;
}
.empty {
  color: #9ca3af;
}


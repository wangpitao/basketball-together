<view class="page">
  <view class="header">我的参与</view>
  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view wx:else>
    <view class="empty" wx:if="{{!list.length}}">暂无参与</view>
    <view class="list" wx:else>
      <view class="list-item" wx:for="{{list}}" wx:key="_id">
        <view class="list-title">{{item.venueName}}｜{{item.displayTime}}</view>
        <view class="list-sub">人数：{{item.displayCount}}｜{{item.address || ''}}</view>
      </view>
    </view>
  </view>
</view>
